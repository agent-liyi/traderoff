# ============================================
# 动态平衡播客 — 腾讯云服务器部署配置
# ============================================
# 复制此文件为 .env.production 并修改

# 数据库：本地 SQLite 文件路径
# 默认存储在项目 data/ 目录，建议放到 /data/podcast/ 下便于备份
SQLITE_DB_PATH=file:/data/podcast/podcast.db

# 后台管理密码
ADMIN_PASSWORD=你的安全密码

# 网站域名（用于 sitemap、OG 标签等）
NEXT_PUBLIC_SITE_URL=https://dongtaipingheng.com

# 服务端口（内部端口，nginx 反向代理到 443/80）
PORT=3000
